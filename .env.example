APP_NAME=Zouple
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://zouple.in

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="Zouple"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# PRODUCTION READINESS NOTE
# 1. Set APP_DEBUG=false
# 2. Set APP_URL to your actual production domain
# 3. Consider setting CACHE_DRIVER=redis or database

# Payment gateway credentials
# Local/testing:
# PAYPAL_MODE=sandbox
# PAYTM_ENVIRONMENT=local
# PAYTM_MERCHANT_WEBSITE=WEBSTAGING
# Production/Hostinger:
# PAYPAL_MODE=live
# PAYTM_ENVIRONMENT=production
# PAYTM_MERCHANT_WEBSITE=DEFAULT
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

PAYTM_ENVIRONMENT=local
PAYTM_MERCHANT_ID=
PAYTM_MERCHANT_KEY=
PAYTM_MERCHANT_WEBSITE=WEBSTAGING
PAYTM_CHANNEL=WEB
PAYTM_INDUSTRY_TYPE=Retail

# Zouple production settings
# Configure the public business WhatsApp number from admin Site Information when possible.
# Format: country code + number, digits only, for example 919876543210.
ZOUPLE_SUPPORT_EMAIL=

# Cloudinary media storage
# CLOUDINARY_CLOUD_NAME must be the real Cloudinary "Cloud name" from Dashboard.
# Do not use the API key name/display label such as "Zouple_123".
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=zouple
